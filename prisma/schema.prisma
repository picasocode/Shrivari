generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String   // "LT Panels" or "HT Panels"
  description String
  features    String   // JSON array of features
  imageUrl    String   @default("")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  icon        String   @default("")
  features    String   @default("[]") // JSON array
  imageUrl    String   @default("")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  name        String
  industry    String   @default("")
  location    String   @default("")
  logoUrl     String   @default("")
  description String   @default("")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  company     String
  designation String   @default("")
  content     String
  rating      Int      @default(5)
  videoUrl    String   @default("")
  imageUrl    String   @default("")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String   @default("")
  content      String   @default("")
  coverImageUrl String  @default("")
  author       String   @default("Shri Vaari")
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  subject   String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String
  location    String
  description String
  imageUrl    String   @default("")
  category    String   @default("ongoing") // "ongoing" or "completed"
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id            String   @id @default(cuid())
  name          String
  designation   String
  responsibility String  @default("")
  experience    Int      @default(0)
  initials      String   @default("")
  gradientFrom  String   @default("#1B3A5C")
  gradientTo    String   @default("#2A5F8F")
  accent        String   @default("#1B3A5C")
  linkedinUrl   String   @default("")
  order         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sector {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("Zap")
  stat        String   @default("")
  statLabel   String   @default("")
  gradientFrom String  @default("#1B3A5C")
  gradientTo  String   @default("#2A5F8F")
  accent      String   @default("#1B3A5C")
  details     String   @default("[]") // JSON array of detail strings
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Milestone {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  icon        String   @default("Rocket")
  color       String   @default("#1B3A5C")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  city      String
  state     String
  type      String   @default("Branch Office") // "Headquarters" or "Regional Office" or "Branch Office"
  icon      String   @default("MapPin")
  isHQ      Boolean  @default(false)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Career {
  id          String   @id @default(cuid())
  title       String
  location    String
  experience  String
  department  String
  type        String   @default("Full-time")
  icon        String   @default("Briefcase")
  accent      String   @default("#1B3A5C")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("admin")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectRecord {
  id           String   @id @default(cuid())
  sno          Int      @default(0)
  customerName String
  voltageLevel String   @default("")
  industry     String   @default("")
  scopeOfWork  String   @default("")
  location     String   @default("")
  state        String   @default("")
  projectValue String   @default("")
  year         String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
