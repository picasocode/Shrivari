+      size: 10 + (i * 7) % 14,
+      delay: i * 0.7,
+      duration: 4 + (i % 4) * 1.5,
+    }))
+  }, [names])
+
+  return (
+    <div className="absolute inset-0 overflow-hidden pointer-events-none select-none">
