+  order     Int      @default(0)
+  active    Boolean  @default(true)
+  createdAt DateTime @default(now())
+  updatedAt DateTime @updatedAt
+}
+
+model Career {
+  id          String   @id @default(cuid())
+  title       String
+  location    String
+  experience  String
+  department  String
+  type        String   @default("Full-time")
+  icon        String   @default("Briefcase")
+  accent      String   @default("#1B3A5C")
+  order       Int      @default(0)
+  active      Boolean  @default(true)
+  createdAt   DateTime @default(now())
+  updatedAt   DateTime @updatedAt
+}
+
+model User {
+  id        String    @id @default(cuid())
+  name      String
+  email     String    @unique
+  password  String
+  role      String    @default("admin")
+  active    Boolean   @default(true)
+  createdAt DateTime  @default(now())
+  updatedAt DateTime  @updatedAt
+  sessions  Session[]
+}
+
+model Session {
+  id        String   @id @default(cuid())
+  userId    String
+  token     String   @unique
+  expiresAt DateTime
+  createdAt DateTime @default(now())
+  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
+}
+
+model ProjectRecord {
+  id           String   @id @default(cuid())
+  sno          Int      @default(0)
+  customerName String
+  voltageLevel String   @default("")
+  industry     String   @default("")
+  scopeOfWork  String   @default("")
+  location     String   @default("")
+  state        String   @default("")
+  projectValue String   @default("")
+  year         String   @default("")
+  active       Boolean  @default(true)
+  createdAt    DateTime @default(now())
+  updatedAt    DateTime @updatedAt
+}
