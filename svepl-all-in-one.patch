+} from '@/components/ui/dialog'
+import { fetchBlogs, type Blog } from '@/lib/api'
+
+function BlogCardSkeleton() {
+  return (
+    <Card className="border-none shadow-md rounded-xl overflow-hidden">
+      <Skeleton className="h-40" />
