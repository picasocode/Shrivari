+  title       String
+  description String
+  icon        String   @default("Rocket")
+  color       String   @default("#1B3A5C")
+  order       Int      @default(0)
+  active      Boolean  @default(true)
+  createdAt   DateTime @default(now())
+  updatedAt   DateTime @updatedAt
+}
+
+model Branch {
+  id        String   @id @default(cuid())
+  city      String
+  state     String
+  type      String   @default("Branch Office") // "Headquarters" or "Regional Office" or "Branch Office"
